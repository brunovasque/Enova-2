# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Admin key
# CRM_ADMIN_KEY é a chave canônica do Enova-2/Worker (preferencial).
# ENOVA_ADMIN_KEY é compatibilidade temporária do painel legado (fallback).
# O helper get-admin-key.ts tenta CRM_ADMIN_KEY primeiro; se ausente, usa ENOVA_ADMIN_KEY.
# Defina pelo menos uma das duas. Nunca commitar valores reais.
CRM_ADMIN_KEY=
ENOVA_ADMIN_KEY=

# URL base do Worker Cloudflare do Enova-2
# PROD: https://nv-enova-2.brunovasque.workers.dev
# Nunca commitar valor real aqui.
WORKER_BASE_URL=

# Chave OpenAI — necessária apenas para o módulo ENOVA IA
# Se ausente, ENOVA IA não funciona (não é bloqueante para o CRM)
OPENAI_API_KEY=
